{
  "manifest_version": 3,
  "name": "ChatGPT 对话寻踪",
  "version": "2.0.0",
  "description": "增量保存、完整扫描并搜索你在 ChatGPT 网页中实际打开的对话。",
  "permissions": [
    "storage",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "https://chatgpt.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "打开 ChatGPT 对话寻踪"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": [
        "archive-core.js",
        "search-core.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "panel.css"
      ],
      "matches": [
        "https://chatgpt.com/*"
      ]
    }
  ]
}
